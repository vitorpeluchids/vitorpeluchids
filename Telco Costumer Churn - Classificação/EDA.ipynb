    "# 2. Criar o Heatmap Interativo\n",
    "fig = px.imshow(\n",
    "    corr, \n",
    "    text_auto='.2f', # Exibe os valores dentro dos quadrados\n",
    "    aspect=\"auto\", \n",
    "    color_continuous_scale='RdBu_r', # Escala Red-Blue (bom para ver correlações neg/pos)\n",
    "    title=\"Mapa de Calor: Correlação entre Variáveis de Churn\"\n",
    ")\n",
    "\n",
    "# 3. Ajustar o layout para melhor visualização\n",
    "fig.update_layout(\n",
    "    xaxis_title=\"Variáveis\",\n",
    "    yaxis_title=\"Variáveis\",\n",
    "    width=800, \n",
    "    height=800\n",
    ")\n",
    "\n",
    "fig.show()"
