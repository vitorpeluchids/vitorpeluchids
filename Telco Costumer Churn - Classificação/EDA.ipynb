   "source": [
    "# 1. Definir as colunas numéricas que queremos analisar\n",
    "cols_analise = ['tenure', 'MonthlyCharges', 'TotalCharges']\n",
    "\n",
    "# 2. Criar a estrutura de subplots (1 linha para cada feature)\n",
    "fig = make_subplots(rows=3, cols=1, \n",
    "                    subplot_titles=(f'Distribuição de {cols_analise[0]}', \n",
    "                                    f'Distribuição de {cols_analise[1]}', \n",
    "                                    f'Distribuição de {cols_analise[2]}'))\n",
    "\n",
    "# 3. Adicionar os histogramas em um loop\n",
    "for i, col in enumerate(cols_analise):\n",
    "    # Clientes que saíram (Churn = Yes)\n",
    "    fig.add_trace(\n",
    "        go.Histogram(x=df[df['Churn']=='Yes'][col], name='Churn: Sim', \n",
    "                     marker_color='#EF553B', opacity=0.7),\n",
    "        row=i+1, col=1\n",
    "    )\n",
    "    # Clientes que ficaram (Churn = No)\n",
    "    fig.add_trace(\n",
    "        go.Histogram(x=df[df['Churn']=='No'][col], name='Churn: Não', \n",
    "                     marker_color='#636EFA', opacity=0.7),\n",
    "        row=i+1, col=1\n",
    "    )\n",
    "\n",
    "# 4. Ajustar o layout\n",
    "fig.update_layout(\n",
    "    height=900, \n",
    "    title_text=\"Análise de Features Numéricas vs Churn\",\n",
    "    barmode='overlay', # Sobrepõe os histogramas para facilitar a comparação\n",
    "    showlegend=False\n",
    ")\n",
    "\n",
    "# Ajustar a transparência e legendas repetidas\n",
    "fig.update_traces(xbins=dict(size=2)) # Opcional: ajustar a largura das barras\n",
    "fig.show()"
   ]
  },
