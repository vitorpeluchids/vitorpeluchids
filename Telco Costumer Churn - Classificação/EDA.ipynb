   "source": [
    "# 1. Colunas numéricas do dataset\n",
    "cols_analise = ['tenure', 'MonthlyCharges', 'TotalCharges']\n",
    "\n",
    "# 2. Criar subplots (1 linha, 3 colunas)\n",
    "fig = make_subplots(\n",
    "    rows=1, cols=3, \n",
    "    subplot_titles=[f'Dispersão: {col}' for col in cols_analise]\n",
    ")\n",
    "\n",
    "# 3. Adicionar a dispersão (Strip Plot)\n",
    "for i, col in enumerate(cols_analise):\n",
    "    # Clientes que Não saíram (Azul)\n",
    "    fig.add_trace(\n",
    "        go.Box(\n",
    "            y=df[df['Churn']=='No'][col],\n",
    "            name='Não',\n",
    "            boxpoints='all',      # Mostra TODOS os pontos\n",
    "            jitter=0.5,           # Espalha os pontos lateralmente para não sobrepor\n",
    "            pointpos=0,           # Coloca os pontos no centro\n",
    "            fillcolor='rgba(0,0,0,0)', # Deixa a caixa invisível\n",
    "            line=dict(color='rgba(0,0,0,0)'), # Deixa as linhas da caixa invisíveis\n",
    "            marker=dict(color='#636EFA', size=2, opacity=0.4),\n",
    "            showlegend=False\n",
    "        ),\n",
    "        row=1, col=i+1\n",
    "    )\n",
    "    \n",
    "    # Clientes que Sim, saíram (Vermelho)\n",
    "    fig.add_trace(\n",
    "        go.Box(\n",
    "            y=df[df['Churn']=='Yes'][col],\n",
    "            name='Sim',\n",
    "            boxpoints='all',\n",
    "            jitter=0.5,\n",
    "            pointpos=0,\n",
    "            fillcolor='rgba(0,0,0,0)',\n",
    "            line=dict(color='rgba(0,0,0,0)'),\n",
    "            marker=dict(color='#EF553B', size=2, opacity=0.4),\n",
    "            showlegend=False\n",
    "        ),\n",
    "        row=1, col=i+1\n",
    "    )\n",
    "\n",
    "# 4. Ajustes de Layout\n",
    "fig.update_layout(\n",
    "    title_text=\"Dispersão Individual dos Clientes por Churn\",\n",
    "    height=500,\n",
    "    template=\"plotly_dark\"\n",
    ")\n",
    "\n",
    "fig.show()"
   ]
  },
