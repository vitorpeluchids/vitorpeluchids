    "                   text_auto=True, # Adiciona os números em cima das barras\n",
    "                   color_discrete_sequence=[\"#636EFA\", \"#EF553B\"]) # Cores customizadas\n",
    "\n",
    "fig.update_layout(yaxis_title=\"Quantidade de Clientes\", xaxis_title=\"Churn\")\n",
    "fig.show()"
   ]
