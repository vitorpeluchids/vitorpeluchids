   "source": [
    "# 1. Colunas numéricas do dataset IBM Telco\n",
    "cols_analise = ['tenure', 'MonthlyCharges', 'TotalCharges']\n",
    "\n",
    "# 2. Criar subplots (1 linha, 3 colunas)\n",
    "fig = make_subplots(\n",
    "    rows=1, cols=3, \n",
    "    subplot_titles=[f'Boxplot: {col}' for col in cols_analise]\n",
    ")\n",
    "\n",
    "# 3. Adicionar os Boxplots\n",
    "for i, col in enumerate(cols_analise):\n",
    "    # Grupo: Não cancelou (Churn: No)\n",
    "    fig.add_trace(\n",
    "        go.Box(\n",
    "            y=df[df['Churn']=='No'][col],\n",
    "            name='Não',\n",
    "            marker_color='#636EFA',\n",
    "            boxmean=True # Linha tracejada para a média (opcional)\n",
    "        ),\n",
    "        row=1, col=i+1\n",
    "    )\n",
    "    \n",
    "    # Grupo: Cancelou (Churn: Yes)\n",
    "    fig.add_trace(\n",
    "        go.Box(\n",
    "            y=df[df['Churn']=='Yes'][col],\n",
    "            name='Sim',\n",
    "            marker_color='#EF553B',\n",
    "            boxmean=True\n",
    "        ),\n",
    "        row=1, col=i+1\n",
    "    )\n",
    "\n",
    "# 4. Ajustes de Layout\n",
    "fig.update_layout(\n",
    "    title_text=\"Distribuição Estatística das Features por Churn\",\n",
    "    height=500,\n",
    "    showlegend=False, # Como os nomes já estão nos eixos, a legenda é opcional\n",
    "    template=\"plotly_dark\"\n",
    ")\n",
    "\n",
    "fig.show()"
   ]
  },
